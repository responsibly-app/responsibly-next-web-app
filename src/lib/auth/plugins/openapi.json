        "/zoom/meetings": {
            "get": {
                "operationId": "zoom.meetings.list",
                "summary": "List meetings",
                "tags": [
                    "Zoom"
                ],
                "parameters": [
                    {
                        "name": "type",
                        "in": "query",
                        "schema": {
                            "default": "upcoming",
                            "enum": [
                                "scheduled",
                                "live",
                                "upcoming"
                            ],
                            "description": "Filter by meeting type"
                        },
                        "style": "deepObject",
                        "explode": true,
                        "allowEmptyValue": true,
                        "allowReserved": true
                    },
                    {
                        "name": "page_size",
                        "in": "query",
                        "schema": {
                            "default": 30,
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 300,
                            "description": "Number of records per page"
                        },
                        "allowEmptyValue": true,
                        "allowReserved": true
                    },
                    {
                        "name": "page_number",
                        "in": "query",
                        "schema": {
                            "default": 1,
                            "type": "integer",
                            "minimum": 1,
                            "description": "Page number"
                        },
                        "allowEmptyValue": true,
                        "allowReserved": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "page_count": {
                                            "type": "number"
                                        },
                                        "page_number": {
                                            "type": "number"
                                        },
                                        "page_size": {
                                            "type": "number"
                                        },
                                        "total_records": {
                                            "type": "number"
                                        },
                                        "meetings": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "number"
                                                    },
                                                    "uuid": {
                                                        "type": "string"
                                                    },
                                                    "host_id": {
                                                        "type": "string"
                                                    },
                                                    "topic": {
                                                        "type": "string"
                                                    },
                                                    "type": {
                                                        "type": "number",
                                                        "description": "1=instant, 2=scheduled, 3=recurring (no fixed time), 8=recurring (fixed time)"
                                                    },
                                                    "status": {
                                                        "type": "string"
                                                    },
                                                    "start_time": {
                                                        "type": "string"
                                                    },
                                                    "duration": {
                                                        "type": "number",
                                                        "description": "Duration in minutes"
                                                    },
                                                    "timezone": {
                                                        "type": "string"
                                                    },
                                                    "created_at": {
                                                        "type": "string"
                                                    },
                                                    "join_url": {
                                                        "type": "string"
                                                    },
                                                    "agenda": {
                                                        "type": "string"
                                                    },
                                                    "password": {
                                                        "type": "string"
                                                    }
                                                },
                                                "required": [
                                                    "id",
                                                    "uuid",
                                                    "host_id",
                                                    "topic",
                                                    "type"
                                                ]
                                            }
                                        }
                                    },
                                    "required": [
                                        "page_count",
                                        "page_number",
                                        "page_size",
                                        "total_records",
                                        "meetings"
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "operationId": "zoom.meetings.create",
                "summary": "Create a new meeting",
                "tags": [
                    "Zoom"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "topic": {
                                        "type": "string",
                                        "description": "Meeting topic / title"
                                    },
                                    "type": {
                                        "type": "integer",
                                        "description": "1=instant, 2=scheduled, 3=recurring (no fixed time), 8=recurring (fixed time)"
                                    },
                                    "start_time": {
                                        "type": "string",
                                        "description": "ISO 8601 datetime, e.g. 2026-03-20T10:00:00Z"
                                    },
                                    "duration": {
                                        "type": "integer",
                                        "description": "Duration in minutes"
                                    },
                                    "timezone": {
                                        "type": "string"
                                    },
                                    "agenda": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "settings": {
                                        "type": "object",
                                        "properties": {
                                            "host_video": {
                                                "type": "boolean"
                                            },
                                            "participant_video": {
                                                "type": "boolean"
                                            },
                                            "join_before_host": {
                                                "type": "boolean"
                                            },
                                            "mute_upon_entry": {
                                                "type": "boolean"
                                            },
                                            "waiting_room": {
                                                "type": "boolean"
                                            }
                                        }
                                    }
                                },
                                "required": [
                                    "topic"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "number"
                                        },
                                        "uuid": {
                                            "type": "string"
                                        },
                                        "host_id": {
                                            "type": "string"
                                        },
                                        "topic": {
                                            "type": "string"
                                        },
                                        "type": {
                                            "type": "number",
                                            "description": "1=instant, 2=scheduled, 3=recurring (no fixed time), 8=recurring (fixed time)"
                                        },
                                        "status": {
                                            "type": "string"
                                        },
                                        "start_time": {
                                            "type": "string"
                                        },
                                        "duration": {
                                            "type": "number",
                                            "description": "Duration in minutes"
                                        },
                                        "timezone": {
                                            "type": "string"
                                        },
                                        "created_at": {
                                            "type": "string"
                                        },
                                        "join_url": {
                                            "type": "string"
                                        },
                                        "agenda": {
                                            "type": "string"
                                        },
                                        "password": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "id",
                                        "uuid",
                                        "host_id",
                                        "topic",
                                        "type"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
