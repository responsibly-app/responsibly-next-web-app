                                                            "type": "string"
                                                        },
                                                        {
                                                            "type": "string",
                                                            "format": "date-time",
                                                            "x-native-type": "date"
                                                        }
                                                    ]
                                                },
                                                "updatedAt": {
                                                    "anyOf": [
                                                        {
                                                            "type": "string"
                                                        },
                                                        {
                                                            "type": "string",
                                                            "format": "date-time",
                                                            "x-native-type": "date"
                                                        }
                                                    ]
                                                },
