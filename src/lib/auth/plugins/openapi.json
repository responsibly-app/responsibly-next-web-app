    "paths": {
        "/session/me": {
            "get": {
                "operationId": "session.me",
                "summary": "Get the current authenticated user",
                "tags": [
                    "Session"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "string"
                                        },
                                        "name": {
                                            "type": "string"
                                        },
                                        "email": {
                                            "type": "string",
                                            "format": "email"
                                        },
                                        "emailVerified": {
                                            "type": "boolean"
                                        },
                                        "image": {
                                            "anyOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "null"
                                                }
                                            ]
                                        },
                                        "createdAt": {
                                            "anyOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "x-native-type": "date"
                                                }
                                            ]
                                        },
                                        "updatedAt": {
                                            "anyOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "x-native-type": "date"
                                                }
                                            ]
                                        }
                                    },
                                    "required": [
                                        "id",
                                        "name",
                                        "email",
                                        "emailVerified",
                                        "createdAt",
                                        "updatedAt"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
